  {
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claudeignore-guard.py",
            "timeout": 10,
            "statusMessage": "Checking .claudeignore..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/hook-guardian.py",
            "timeout": 10,
            "statusMessage": "Checking safety boundary..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/secret-scanner.py",
            "timeout": 30,
            "statusMessage": "Scanning for secrets..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/code-quality.py",
            "timeout": 15,
            "statusMessage": "Checking code quality..."
          }
        ]
      }
    ]
  },
}
